# ── Local development (npm run dev) ──────────────────────────────────────────
# In dev, the app calls the APIs directly using these VITE_ vars so you don't
# need to run the serverless functions locally. These are ONLY used in dev.
VITE_TMDB_API_KEY=your_tmdb_key_here
VITE_GROQ_API_KEY=your_groq_key_here
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_key_here

# ── Production (Vercel) ───────────────────────────────────────────────────────
# In production the app calls /api/* serverless proxies, which read these
# server-side (NO "VITE_" prefix, so they are never exposed to the browser).
# Set these in the Vercel dashboard → Project → Settings → Environment Variables.
# Do NOT also set the VITE_ versions in Vercel, or the keys would ship to the client.
#   GROQ_API_KEY=...
#   TMDB_API_KEY=...
#   UNSPLASH_ACCESS_KEY=...

# ── Cloud accounts / sync (Supabase) ─────────────────────────────────────────
# These are PUBLIC, client-safe keys (anon / publishable), so the VITE_ prefix
# is correct here — set them in BOTH local .env and Vercel. Cloud sync stays
# fully disabled (app works local-only) until these are present.
VITE_SUPABASE_URL=https://vtjmrqhjxefrszunnciy.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_vKfrBQaWMjzilzhJ4kzO1w_XSjg0vce
